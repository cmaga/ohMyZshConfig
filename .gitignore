# Ignore cloned repositories in skills dependencies
# These are fetched at deploy time via the update-repo.zsh scripts
src/storage/claude/skills/*/dependencies/repos/*/

# Temp files
/src/storage/claude/temp-docs

# Skill artifacts (runtime data, per-ticket)
# These are created at runtime in target projects
src/storage/claude/skills/*/artifacts/*
!src/storage/claude/skills/*/artifacts/.gitkeep

# tasks locks for claude
.claude/scheduled_tasks.lock

# Scratch area for hang-investigation load-gen workers.
# Each subdir contains a dummy .envrc + generated worker output.
# Never committed.
/testing_grounds/

# Runtime outputs from scripts/bench-startup.zsh:
#  - bench-samples/ contains macOS sample(1) dumps, often empty for short spawns
#  - bench-sys.log is a per-sample sys-state log, regenerated each run
# bench-results.log IS tracked (historical benchmark record - see docs/terminal-hangs.md).
/scripts/bench-samples/
/scripts/bench-sys.log
